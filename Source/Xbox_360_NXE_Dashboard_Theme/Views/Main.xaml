<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                    mc:Ignorable="d">

    <Style TargetType="{x:Type Main}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Main}">
                    <Grid x:Name="PART_MainHost"
                          d:DesignWidth="{StaticResource DesignWidth}"
                          d:DesignHeight="{StaticResource DesignHeight}"
                          d:DataContext="{x:Static DesignMainViewModel.DesignIntance}">
                        <Grid x:Name="PART_ViewHost">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Image Grid.RowSpan="3" Source="{ThemeFile 'Images/Standard NXE.png'}"
                                   Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            
                            <FadeImage x:Name="PART_ImageBackground" Grid.RowSpan="3"
                                       HorizontalAlignment="Center" VerticalAlignment="Top" Opacity="0"/>

                            <Grid Grid.Row="0" Background="{DynamicResource BottomBarBackgroundBrush}"
                                  Height="60">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="40" />
                                </Grid.ColumnDefinitions>
                                
                                <Border Grid.ColumnSpan="4" BorderBrush="{DynamicResource NXEGreenBrush}" 
                                        BorderThickness="0,0,0,2" VerticalAlignment="Bottom"/>
                                
                                <FilterPresetSelector x:Name="PART_FilterPresetSelector" 
                                                      Grid.Column="1" 
                                                      VerticalAlignment="Center" 
                                                      HorizontalAlignment="Left"
                                                      Margin="0,0,0,0"
                                                      Visibility="Collapsed"
                                                      Focusable="False"
                                                      IsHitTestVisible="False"/>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                                    <TextBlock x:Name="PART_TextClock" Style="{DynamicResource TextBlockBaseStyle}"
                                           VerticalAlignment="Center" Margin="20,0,20,0" FontSize="18"/>
                                    
                                    <ContentControl x:Name="PART_ElemBatteryStatus" Focusable="False" FontSize="24"
                                                VerticalAlignment="Center" Margin="0,0,10,0">
                                        <ContentControl.Style>
                                            <Style TargetType="ContentControl">
                                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PowerStatus.Charge}" Value="Critical">
                                                        <Setter Property="Content" Value="{DynamicResource BatteryStatusCritical}" />
                                                        <Setter Property="Foreground" Value="Red" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PowerStatus.Charge}" Value="Low">
                                                        <Setter Property="Content" Value="{DynamicResource BatteryStatusLow}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PowerStatus.Charge}" Value="Medium">
                                                        <Setter Property="Content" Value="{DynamicResource BatteryStatusMedium}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PowerStatus.Charge}" Value="High">
                                                        <Setter Property="Content" Value="{DynamicResource BatteryStatusHigh}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PowerStatus.IsCharging}" Value="True">
                                                        <Setter Property="Content" Value="{DynamicResource BatteryStatusCharging}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ContentControl.Style>
                                    </ContentControl>
                                    <TextBlock x:Name="PART_TextBatteryPercentage" Style="{DynamicResource TextBlockBaseStyle}"
                                           VerticalAlignment="Center" Margin="0,0,10,0" FontSize="16"/>

                                    <ButtonEx x:Name="PART_ButtonNotifications" VerticalAlignment="Center"
                                              Margin="5,0,5,0" Height="32" MinWidth="32"
                                              Focusable="False" IsHitTestVisible="False">
                                        <Button.Content>
                                            <Grid>
                                                <TextBlock Text="&#xeea3;" FontFamily="{StaticResource FontIcoFont}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="White" FontSize="20" />
                                            </Grid>
                                        </Button.Content>
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ButtonTopMenu}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Api Notifications.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </ButtonEx>

                                    <ButtonEx x:Name="PART_ButtonMainMenu" VerticalAlignment="Center"
                                              Style="{DynamicResource ButtonTopMenu}"
                                              Margin="5,0,5,0" Height="32" MinWidth="32"
                                              Focusable="False" FocusVisualStyle="{x:Null}">
                                        <Button.Content>
                                            <Image RenderOptions.BitmapScalingMode="Fant" Width="28" Height="28"
                                               Source="{ThemeFile 'Images/Xbox Logo.png'}" />
                                        </Button.Content>
                                    </ButtonEx>
                                    
                                    <ButtonEx x:Name="PART_ButtonProgramUpdate" VerticalAlignment="Center"
                                              Margin="5,0,5,0" Height="32" MinWidth="32"
                                              Style="{DynamicResource ButtonTopMenu}"
                                              Focusable="False" FocusVisualStyle="{x:Null}">
                                        <ButtonEx.Content>
                                            <TextBlock Text="&#xef08;" FontFamily="{StaticResource FontIcoFont}"                                                   
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource GlyphLightBrush}" FontSize="20" />
                                        </ButtonEx.Content>
                                    </ButtonEx>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <Filters x:Name="PART_ElemFilters"
                                         Grid.Column="0" Focusable="False" />

                                <ContentControl x:Name="PART_ContentFilterItems"
                                            Grid.Column="0" Focusable="False" />

                                <Grid Grid.Column="1">
                                    <!-- Hidden default game list (required by Playnite but invisible) -->
                                    <ListBoxEx x:Name="PART_ListGameItems"
                                               Width="0" Height="0" Opacity="0"
                                               IsHitTestVisible="False"
                                               Background="Transparent" BorderThickness="0"
                                               ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                               ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                               KeyboardNavigation.DirectionalNavigation="None"
                                               Focusable="False"/>
                                    
                                    <!-- Custom NXE Game Carousel from extension -->
                                    <ContentControl x:Name="NXEGameList_GameCarousel" 
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Stretch"
                                                    Height="420"
                                                    Margin="20,0"/>
                                </Grid>
                            </Grid>

                            <TextBlock Grid.Row="1" FontSize="40"
                                       Text="{DynamicResource LOCNoGamesFound}"
                                       TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource TextBlockBaseStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Items.Count, ElementName=PART_ListGameItems}" Value="0">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Grid Grid.Row="2" Background="{DynamicResource BottomBarBackgroundBrush}"
                              Height="60">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="40" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <ButtonEx x:Name="PART_ButtonPlay" Visibility="Collapsed"
                                              Style="{DynamicResource ButtonBottomMenu}"
                                              InputHint="{DynamicResource ButtonPromptA}"
                                              Content="{DynamicResource LOCPlayGame}" />
                                    <ButtonEx x:Name="PART_ButtonDetails" Visibility="Collapsed"
                                              Style="{DynamicResource ButtonBottomMenu}"
                                              InputHint="{DynamicResource ButtonPromptX}"
                                              Content="{DynamicResource LOCGameDetails}" />
                                    <ButtonEx x:Name="PART_ButtonInstall" Visibility="Collapsed"
                                              Style="{DynamicResource ButtonBottomMenu}"
                                              Content="{DynamicResource LOCInstallGame}" />
                                    <ButtonEx x:Name="PART_ButtonGameOptions" Visibility="Collapsed"
                                              Style="{DynamicResource ButtonBottomMenu}"
                                              Content="{DynamicResource LOCGameOptions}" />
                                    <ButtonEx x:Name="PART_ButtonSearch" Visibility="Collapsed"
                                              Style="{DynamicResource ButtonBottomMenu}"
                                              Content="{DynamicResource LOCSearchLabel}" />
                                    <ButtonEx x:Name="PART_ButtonFilter" Visibility="Collapsed"
                                              Style="{DynamicResource ButtonBottomMenu}"
                                              Content="{DynamicResource LOCFilter}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" x:Name="PART_ElemSearchActive"
                                            VerticalAlignment="Center" HorizontalAlignment="Center"
                                            Orientation="Horizontal">
                                    <TextBlock FontSize="16" Style="{DynamicResource TextBlockBaseStyle}"
                                               Text="{DynamicResource LOCGameListSearchResults}" Margin="0,0,10,0"/>
                                    <TextBlock Foreground="White" Style="{DynamicResource TextBlockBaseStyle}"
                                               FontSize="16" FontWeight="Bold"
                                               Text="{Binding AppSettings.Fullscreen.FilterSettings.Name}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" x:Name="PART_ElemExtraFilterActive"
                                       FontSize="16"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Style="{DynamicResource TextBlockBaseStyle}"
                                       Text="{DynamicResource LOCGameListExtraFiltered}"/>

                                <StackPanel x:Name="PART_ElemProgressIndicator" Orientation="Horizontal"
                                        Grid.Column="3" VerticalAlignment="Center">
                                    <TextBlock x:Name="PART_TextProgressTooltip" 
                                           Margin="0,0,10,0" FontSize="14" VerticalAlignment="Center"
                                           Style="{DynamicResource TextBlockBaseStyle}"/>
                                    <ContentControl Style="{DynamicResource ProgressIndicator}" Focusable="False"
                                                Height="28" Width="28" VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <GameDetails x:Name="PART_ElemGameDetails" Grid.RowSpan="3"
                                     HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

                        <GameStatus x:Name="PART_ElemGameStatus" Grid.RowSpan="3"
                                     HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>