<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    mc:Ignorable="d">

    <Color x:Key="BlackColor">#FF000000</Color>
    <Color x:Key="WhiteColor">#FFFFFFFF</Color>
    <Color x:Key="GlyphColor">#FF9BC848</Color>
    <Color x:Key="GlyphLightColor">#FFB4E455</Color>
    <Color x:Key="SelectionLightColor">#FF9BC848</Color>
    <Color x:Key="OverlayColor">#DD000000</Color>
    
    <Color x:Key="ControlBackgroundColor">#FF3A3A3A</Color>
    <Color x:Key="ControlBackgroundColorDark">#FF1A1A1A</Color>

    <Color x:Key="TextColor">#FFFFFFFF</Color>
    <Color x:Key="TextColorDark">#FF888888</Color>
    
    <Color x:Key="NXEGreen">#FF9BC848</Color>
    <Color x:Key="NXEGreenLight">#FFB4E455</Color>
    <Color x:Key="NXEGray">#FF4A4A4A</Color>
    <Color x:Key="NXEDarkGray">#FF2A2A2A</Color>
    <Color x:Key="NXERowBackground">#CC2A2A2A</Color>

    <SolidColorBrush x:Key="TextBrush" Color="{DynamicResource TextColor}" />
    <SolidColorBrush x:Key="TextBrushDark" Color="{DynamicResource TextColorDark}" />
    <SolidColorBrush x:Key="GlyphBrush" Color="{DynamicResource GlyphColor}" />
    <SolidColorBrush x:Key="GlyphLightBrush" Color="{DynamicResource GlyphLightColor}" />
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="{DynamicResource ControlBackgroundColor}" />
    <SolidColorBrush x:Key="ControlBackgroundDarkBrush" Color="{DynamicResource ControlBackgroundColorDark}" />
    <SolidColorBrush x:Key="SelectionLightBrush" Color="{DynamicResource SelectionLightColor}" />
    <SolidColorBrush x:Key="OverlayBrush" Color="{DynamicResource OverlayColor}" />
    <SolidColorBrush x:Key="CheckBoxCheckMarkBkBrush" Color="{DynamicResource ControlBackgroundColorDark}" />
    <SolidColorBrush x:Key="NXEGreenBrush" Color="{DynamicResource NXEGreen}" />
    <SolidColorBrush x:Key="NXERowBackgroundBrush" Color="{DynamicResource NXERowBackground}" />

    <sys:Double x:Key="FontSizeSmall">18</sys:Double>
    <sys:Double x:Key="FontSize">22</sys:Double>

    <sys:Double x:Key="FilterPanelWidth">300</sys:Double>
    
    <GridLength x:Key="ProgressWindowWidth">640</GridLength>
    
    <Style x:Key="TextBlockBaseStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource FontSize}" />
        <Setter Property="FontFamily" Value="{DynamicResource FontTitilliumWebLight}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <LinearGradientBrush x:Key="MainBackgourndBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF8BC34A" Offset="0" />
        <GradientStop Color="#FF689F38" Offset="0.3" />
        <GradientStop Color="#FF558B2F" Offset="0.6" />
        <GradientStop Color="#FF33691E" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="TopBarBackgroundBrush" StartPoint="0,0" EndPoint="0,1" >
        <GradientStop Color="#00000000" Offset="0"/>
        <GradientStop Color="#00000000" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BottomBarBackgroundBrush" StartPoint="0,0" EndPoint="0,1" >
        <GradientStop Color="#44000000" Offset="0"/>
        <GradientStop Color="#66000000" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="OverlayMenuBackgroundBrush" StartPoint="0.5,0" EndPoint="0.5,1" >
        <GradientStop Color="#FF2A2A2A" Offset="0"/>
        <GradientStop Color="#FF1A1A1A" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SelectionBrush" StartPoint="0,0" EndPoint="0,1" >
        <GradientStop Color="#FF9BC848" Offset="0"/>
        <GradientStop Color="#FF7BA830" Offset="1.0"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GameDetailsBackgroundBrush" StartPoint="0.5,0" EndPoint="0.5,0.4" >
        <GradientStop Color="#00000000" Offset="0.0"/>
        <GradientStop Color="#EE1A1A1A" Offset="0.8"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="NXERowGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#00000000" Offset="0"/>
        <GradientStop Color="#00000000" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="NXETileGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFAED581" Offset="0"/>
        <GradientStop Color="#FF8BC34A" Offset="0.5"/>
        <GradientStop Color="#FF689F38" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="NXETileSelectedGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFCDDC39" Offset="0"/>
        <GradientStop Color="#FFAED581" Offset="0.5"/>
        <GradientStop Color="#FF8BC34A" Offset="1"/>
    </LinearGradientBrush>
    
    <SolidColorBrush x:Key="WarningBrush" Color="#ff6b6b" />
</ResourceDictionary>