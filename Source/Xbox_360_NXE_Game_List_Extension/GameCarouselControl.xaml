<pn:PluginUserControl x:Class="NXEGameList.GameCarouselControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:pn="clr-namespace:Playnite.SDK.Controls;assembly=Playnite.SDK"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="1400"
             Focusable="True"
             FocusVisualStyle="{x:Null}">
    <pn:PluginUserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </pn:PluginUserControl.Resources>
    
    <Grid>
        <!-- Top Panel - Filter Info (above icons) -->
        <StackPanel VerticalAlignment="Top" Margin="20,-45,0,0">
            <!-- Previous filter (dimmed) -->
            <TextBlock Text="{Binding PreviousFilterName}" Foreground="#66FFFFFF" 
                       FontSize="24" Margin="0,0,0,4" TextTrimming="None" TextWrapping="NoWrap">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="1" Color="Black" Opacity="0.5" BlurRadius="2"/>
                </TextBlock.Effect>
            </TextBlock>
            
            <!-- Current filter with bullet -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="• " Foreground="#00FF00" FontSize="32" FontWeight="Bold"/>
                <TextBlock Text="{Binding CurrentFilterName}" Foreground="White" 
                           FontSize="32" FontWeight="SemiBold" TextTrimming="None" TextWrapping="NoWrap">
                    <TextBlock.Effect>
                        <DropShadowEffect ShadowDepth="1" Color="Black" Opacity="0.7" BlurRadius="3"/>
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>
            
            <!-- Next filter (dimmed) -->
            <TextBlock Text="{Binding NextFilterName}" Foreground="#66FFFFFF" 
                       FontSize="24" Margin="0,0,0,0" TextTrimming="None" TextWrapping="NoWrap">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="1" Color="Black" Opacity="0.5" BlurRadius="2"/>
                </TextBlock.Effect>
            </TextBlock>
        </StackPanel>
        
        <!-- Bottom Panel - Title and Count (absolute positioned at bottom) -->
        <StackPanel VerticalAlignment="Bottom" Margin="20,0,0,10">
            <!-- Selected Game Title -->
            <TextBlock Text="{Binding SelectedGameName}" Foreground="White" 
                       FontSize="24" FontWeight="Bold" TextWrapping="Wrap"
                       MaxWidth="600" HorizontalAlignment="Left">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="2" Color="Black" Opacity="0.8" BlurRadius="4"/>
                </TextBlock.Effect>
            </TextBlock>
            
            <!-- Game count indicator -->
            <TextBlock Foreground="#99FFFFFF" FontSize="22" Margin="0,8,0,0">
                <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0} of {1}">
                        <Binding Path="CurrentGameIndex"/>
                        <Binding Path="TotalGameCount"/>
                    </MultiBinding>
                </TextBlock.Text>
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="1" Color="Black" Opacity="0.5" BlurRadius="2"/>
                </TextBlock.Effect>
            </TextBlock>
        </StackPanel>
        
        <!-- Game Items Panel (centered) -->
        <Border Background="Transparent" ClipToBounds="False" 
                VerticalAlignment="Center" Margin="20,0,0,0">
            <ItemsControl ItemsSource="{Binding VisibleGames}" 
                          HorizontalAlignment="Left" VerticalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Panel.ZIndex" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StackIndex}" Value="0">
                                <Setter Property="Panel.ZIndex" Value="10"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StackIndex}" Value="1">
                                <Setter Property="Panel.ZIndex" Value="9"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StackIndex}" Value="2">
                                <Setter Property="Panel.ZIndex" Value="8"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StackIndex}" Value="3">
                                <Setter Property="Panel.ZIndex" Value="7"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StackIndex}" Value="4">
                                <Setter Property="Panel.ZIndex" Value="6"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StackIndex}" Value="5">
                                <Setter Property="Panel.ZIndex" Value="5"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StackIndex}" Value="6">
                                <Setter Property="Panel.ZIndex" Value="4"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StackIndex}" Value="7">
                                <Setter Property="Panel.ZIndex" Value="3"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StackIndex}" Value="8">
                                <Setter Property="Panel.ZIndex" Value="2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- FreeStyle Dash style: LARGER tiles with 16:9 aspect ratio for background images -->
                        <Grid Width="400" Height="225">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="RenderTransformOrigin" Value="0,0.5"/>
                                    <Style.Triggers>
                                        <!-- Position 0 - full size, no offset -->
                                        <DataTrigger Binding="{Binding StackIndex}" Value="0">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TransformGroup>
                                                        <TranslateTransform X="0"/>
                                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                    </TransformGroup>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                        <!-- Position 1 - barely overlapped -->
                                        <DataTrigger Binding="{Binding StackIndex}" Value="1">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TransformGroup>
                                                        <TranslateTransform X="300"/>
                                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                                    </TransformGroup>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                        <!-- Position 2 -->
                                        <DataTrigger Binding="{Binding StackIndex}" Value="2">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TransformGroup>
                                                        <TranslateTransform X="555"/>
                                                        <ScaleTransform ScaleX="0.94" ScaleY="0.94"/>
                                                    </TransformGroup>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                        <!-- Position 3 -->
                                        <DataTrigger Binding="{Binding StackIndex}" Value="3">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TransformGroup>
                                                        <TranslateTransform X="765"/>
                                                        <ScaleTransform ScaleX="0.91" ScaleY="0.91"/>
                                                    </TransformGroup>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                        <!-- Position 4 -->
                                        <DataTrigger Binding="{Binding StackIndex}" Value="4">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TransformGroup>
                                                        <TranslateTransform X="945"/>
                                                        <ScaleTransform ScaleX="0.88" ScaleY="0.88"/>
                                                    </TransformGroup>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                        <!-- Position 5 -->
                                        <DataTrigger Binding="{Binding StackIndex}" Value="5">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TransformGroup>
                                                        <TranslateTransform X="1095"/>
                                                        <ScaleTransform ScaleX="0.85" ScaleY="0.85"/>
                                                    </TransformGroup>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                        <!-- Position 6 -->
                                        <DataTrigger Binding="{Binding StackIndex}" Value="6">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TransformGroup>
                                                        <TranslateTransform X="1222"/>
                                                        <ScaleTransform ScaleX="0.82" ScaleY="0.82"/>
                                                    </TransformGroup>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                        <!-- Position 7 -->
                                        <DataTrigger Binding="{Binding StackIndex}" Value="7">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TransformGroup>
                                                        <TranslateTransform X="1335"/>
                                                        <ScaleTransform ScaleX="0.79" ScaleY="0.79"/>
                                                    </TransformGroup>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                        <!-- Position 8 -->
                                        <DataTrigger Binding="{Binding StackIndex}" Value="8">
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <TransformGroup>
                                                        <TranslateTransform X="1432"/>
                                                        <ScaleTransform ScaleX="0.76" ScaleY="0.76"/>
                                                    </TransformGroup>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Opacity" Value="0.9"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            
                            <!-- Game tile container (for games) -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMenuItem}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <!-- Shadow layer (separate so it doesn't affect clipping) -->
                                <Border CornerRadius="12" Background="#333333">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="3" Opacity="0.4" Color="Black" BlurRadius="10"/>
                                    </Border.Effect>
                                </Border>
                                <!-- Content layer with image using ImageBrush for proper clipping -->
                                <Border CornerRadius="12">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding BackgroundImage}" Stretch="UniformToFill"
                                                    AlignmentX="Center" AlignmentY="Center"
                                                    RenderOptions.BitmapScalingMode="Fant"/>
                                    </Border.Background>
                                    <!-- Game title overlay at bottom -->
                                    <Border VerticalAlignment="Bottom" CornerRadius="0,0,12,12"
                                            Background="#DD000000" Padding="8,6">
                                        <TextBlock Text="{Binding Name}" Foreground="White" 
                                                   FontWeight="SemiBold" FontSize="13"
                                                   TextTrimming="CharacterEllipsis"
                                                   HorizontalAlignment="Left"/>
                                    </Border>
                                </Border>
                            </Grid>
                            
                            <!-- Menu Item Background (for menu items) - FreeStyle Dash green style -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMenuItem}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <!-- Shadow layer (separate so it doesn't affect clipping) -->
                                <Border CornerRadius="12" Background="#FF558B2F">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="3" Opacity="0.4" Color="Black" BlurRadius="10"/>
                                    </Border.Effect>
                                </Border>
                                <!-- Content layer with gradient, properly clipped -->
                                <Border CornerRadius="12" ClipToBounds="True">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF8BC34A" Offset="0"/>
                                            <GradientStop Color="#FF689F38" Offset="0.5"/>
                                            <GradientStop Color="#FF558B2F" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <!-- Icon -->
                                        <TextBlock Text="{Binding MenuIcon}" FontSize="64" 
                                                   Foreground="#DDFFFFFF" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Margin="0,0,0,30"/>
                                        <!-- Title at bottom -->
                                        <Border VerticalAlignment="Bottom" Padding="10,8">
                                            <TextBlock Text="{Binding Name}" Foreground="White" 
                                                       FontWeight="SemiBold" FontSize="14"
                                                       TextWrapping="Wrap" TextAlignment="Left"
                                                       HorizontalAlignment="Left"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                            
                            <!-- Selection highlight border - subtle -->
                            <Border CornerRadius="12" BorderThickness="2" BorderBrush="{Binding BorderBrush}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect ShadowDepth="0" Color="#92C83E" Opacity="0.5" BlurRadius="10"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </Grid>
</pn:PluginUserControl>
