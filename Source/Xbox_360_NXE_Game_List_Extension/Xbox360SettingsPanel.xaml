<UserControl x:Class="NXEGameList.Xbox360SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             KeyDown="Panel_KeyDown">
    
    <Grid Width="1280" Height="500" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        
        <!-- Left Panel -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#EE000000" Offset="0"/>
                    <GradientStop Color="#EE1A1A1A" Offset="0.8"/>
                    <GradientStop Color="#EE2A2A2A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Header - changes from "System Settings" to category name -->
                <TextBlock x:Name="LeftHeader" Grid.Row="0"
                           Text="System Settings" FontSize="32" 
                           Foreground="White" FontWeight="SemiBold"
                           Margin="20,30,20,20" />
                
                <!-- Category list (shown at top level) -->
                <ListBox x:Name="CategoryList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                         SelectedIndex="0" SelectionChanged="CategoryList_SelectionChanged"
                         KeyDown="CategoryList_KeyDown"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                
                <!-- Settings list (replaces category list when a category is opened) -->
                <ListBox x:Name="SettingsList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                         Visibility="Collapsed" KeyDown="SettingsList_KeyDown"
                         SelectionChanged="SettingsList_SelectionChanged"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.CanContentScroll="True"/>
            </Grid>
        </Border>
        
        <!-- Right Panel - shows description/status -->
        <Border Grid.Column="1" Padding="40,30,40,30">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#DD000000" Offset="0"/>
                    <GradientStop Color="#DD1A1A1A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            
            <Grid>
                <!-- Category description (shown at top level) -->
                <StackPanel x:Name="CategoryInfoPanel" VerticalAlignment="Center">
                    <TextBlock x:Name="CategoryTitle" Text="General" FontSize="36" 
                               Foreground="#FF9BC848" FontWeight="SemiBold"
                               Margin="0,0,0,20" />
                    <TextBlock x:Name="CategoryDescription" 
                               Text="Configure general Playnite settings including startup behavior, update checking, and library management options." 
                               FontSize="20" Foreground="White" TextWrapping="Wrap"
                               LineHeight="28" />
                </StackPanel>
                
                <!-- Setting detail (shown when inside a category) -->
                <StackPanel x:Name="SettingDetailPanel" Visibility="Collapsed" VerticalAlignment="Center">
                    <TextBlock x:Name="SettingName" Text="" FontSize="32" 
                               Foreground="White" FontWeight="SemiBold"
                               Margin="0,0,0,20" />
                    <TextBlock x:Name="SettingStatus" Text="" FontSize="28" 
                               Foreground="#FF9BC848" FontWeight="SemiBold"
                               Margin="0,0,0,30" />
                    <TextBlock x:Name="SettingDescription" Text="" FontSize="18" 
                               Foreground="#CCFFFFFF" TextWrapping="Wrap"
                               LineHeight="26" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
